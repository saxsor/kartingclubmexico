generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  ORGANIZER
  VALIDATOR
  PILOT
}

enum Category {
  SHIFTER
  DOS_TIEMPOS
  FORMULA_MUNDIAL
  NUEVE_HP
  ROOKIES
  MINIS
}

enum EventStatus {
  DRAFT
  OPEN
  IN_PROGRESS
  FINISHED
}

enum InscriptionStatus {
  PENDING_PAYMENT
  RECEIPT_SUBMITTED
  PAID
}

enum PaymentType {
  SERVICE_FEE
  FOOD_FEE
  OTHER
}

enum RaceStatus {
  PENDING
  IN_PROGRESS
  FINISHED
}

enum ResultStatus {
  FINISHED
  DNS
  DNF
  DSQ
}

enum PenaltyType {
  POSITIONS
  POINTS
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String
  role      Role     @default(ORGANIZER)
  active    Boolean  @default(true)
  pilotId   String?  @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  refreshTokens       RefreshToken[]
  passwordResetTokens PasswordResetToken[]
  pilot               Pilot?               @relation(fields: [pilotId], references: [id])
}

model RefreshToken {
  id        String    @id @default(uuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([tokenHash])
}

model PilotMagicToken {
  id        String    @id @default(uuid())
  pilotId   String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  pilot Pilot @relation(fields: [pilotId], references: [id], onDelete: Cascade)

  @@index([tokenHash])
  @@index([pilotId])
}

model PasswordResetToken {
  id        String   @id @default(uuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tokenHash])
}

model Team {
  id        String   @id @default(uuid())
  name      String   @unique
  slug      String   @unique
  logoUrl   String?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  pilots               Pilot[]
  raceResults          RaceResult[]
  constructorStandings ConstructorStanding[]

  @@index([active])
}

model Pilot {
  id           String   @id @default(uuid())
  name         String
  alias        String?
  kartNumber   Int?
  phone        String?
  email        String?
  photoUrl     String?
  engine       String?
  teamId       String?
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  team          Team?                  @relation(fields: [teamId], references: [id], onDelete: SetNull)
  inscriptions  Inscription[]
  standings     ChampionshipStanding[]
  user          User?
  magicTokens   PilotMagicToken[]
  diplomas      ParticipationDiploma[]

  @@index([active])
  @@index([kartNumber])
  @@index([teamId])
}

model Championship {
  id        String   @id @default(uuid())
  name      String
  year      Int
  events    Event[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Event {
  id                 String      @id @default(uuid())
  name               String
  slug               String      @unique
  date               DateTime
  description        String?
  status             EventStatus @default(DRAFT)
  year               Int
  serviceFee         Decimal     @db.Decimal(10, 2) @default(0)
  foodFee            Decimal     @db.Decimal(10, 2) @default(0)
  staffCount         Int         @default(0)
  blockCheckInOnDebt Boolean     @default(false)
  transferInfo       String?
  posterUrl          String?
  diplomaTemplateUrl String?
  diplomaNameY       Float       @default(0.58)
  diplomaFontSize    Int         @default(28)
  diplomaTextColor   String      @default("#111111")
  track              String?
  championshipId     String?
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt

  championship    Championship?   @relation(fields: [championshipId], references: [id], onDelete: SetNull)
  eventCategories EventCategory[]
  inscriptions    Inscription[]
  races           Race[]
  eventGuests     EventGuest[]
  diplomas        ParticipationDiploma[]

  @@index([status])
  @@index([year])
  @@index([championshipId])
}

model EventCategory {
  id       String   @id @default(uuid())
  eventId  String
  category Category
  active   Boolean  @default(true)

  event      Event       @relation(fields: [eventId], references: [id], onDelete: Cascade)
  startGrids StartGrid[]

  @@unique([eventId, category])
}

model Inscription {
  id         String            @id @default(uuid())
  eventId    String
  pilotId    String
  category   Category
  kartNumber Int?
  kartNotes      String?
  engine         String?
  companions     Int               @default(0)
  status         InscriptionStatus @default(PENDING_PAYMENT)
  notes          String?
  receiptPath    String?
  selfRegistered Boolean           @default(false)
  exentoCarrera  Boolean           @default(false)
  exentoComida   Boolean           @default(false)
  createdAt      DateTime          @default(now())
  updatedAt  DateTime          @updatedAt

  event         Event               @relation(fields: [eventId], references: [id], onDelete: Cascade)
  pilot         Pilot               @relation(fields: [pilotId], references: [id])
  payments      Payment[]
  checkIn       CheckIn?
  raceResults   RaceResult[]
  gridPositions StartGridPosition[]
  diplomas      ParticipationDiploma[]

  @@unique([eventId, pilotId, category])
  @@index([eventId])
  @@index([pilotId])
  @@index([status])
}

model Payment {
  id            String      @id @default(uuid())
  inscriptionId String
  type          PaymentType
  amount        Decimal     @db.Decimal(10, 2)
  paidAt        DateTime    @default(now())
  notes         String?
  createdBy     String?
  createdAt     DateTime    @default(now())

  inscription Inscription @relation(fields: [inscriptionId], references: [id], onDelete: Cascade)
}

model CheckIn {
  id            String   @id @default(uuid())
  inscriptionId String   @unique
  kartNumber    Int?
  confirmedAt   DateTime @default(now())
  confirmedBy   String?
  hasDebt       Boolean  @default(false)

  inscription Inscription @relation(fields: [inscriptionId], references: [id], onDelete: Cascade)
}

model EventGuest {
  id        String   @id @default(uuid())
  eventId   String
  name      String?
  count     Int      @default(1)
  isPaid    Boolean  @default(false)
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@index([eventId])
}

model ParticipationDiploma {
  id            String   @id @default(uuid())
  eventId       String
  pilotId       String
  inscriptionId String
  fileUrl       String
  generatedAt   DateTime @default(now())
  updatedAt     DateTime @updatedAt

  event       Event       @relation(fields: [eventId], references: [id], onDelete: Cascade)
  pilot       Pilot       @relation(fields: [pilotId], references: [id])
  inscription Inscription @relation(fields: [inscriptionId], references: [id], onDelete: Cascade)

  @@unique([eventId, pilotId])
  @@index([eventId])
  @@index([pilotId])
  @@index([inscriptionId])
}

model StartGrid {
  id              String   @id @default(uuid())
  eventCategoryId String   @unique
  drawnAt         DateTime @default(now())
  drawnBy         String?

  eventCategory EventCategory       @relation(fields: [eventCategoryId], references: [id], onDelete: Cascade)
  positions     StartGridPosition[]
}

model StartGridPosition {
  id            String @id @default(uuid())
  startGridId   String
  inscriptionId String
  position      Int

  startGrid   StartGrid   @relation(fields: [startGridId], references: [id], onDelete: Cascade)
  inscription Inscription @relation(fields: [inscriptionId], references: [id])

  @@unique([startGridId, position])
  @@unique([startGridId, inscriptionId])
}

model Race {
  id         String     @id @default(uuid())
  eventId    String
  category   Category
  number     Int
  laps       Int        @default(15)
  status     RaceStatus @default(PENDING)
  startedAt  DateTime?
  finishedAt DateTime?
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  event   Event        @relation(fields: [eventId], references: [id], onDelete: Cascade)
  results RaceResult[]

  @@unique([eventId, category, number])
}

model RaceResult {
  id            String       @id @default(uuid())
  raceId        String
  inscriptionId String
  teamId        String?
  position      Int?
  lapsCompleted Int          @default(0)
  status        ResultStatus @default(FINISHED)
  basePoints    Int          @default(0)
  penaltyPoints Int          @default(0)
  finalPoints   Int          @default(0)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  race        Race        @relation(fields: [raceId], references: [id], onDelete: Cascade)
  inscription Inscription @relation(fields: [inscriptionId], references: [id])
  team        Team?       @relation(fields: [teamId], references: [id], onDelete: SetNull)
  penalties   Penalty[]

  @@unique([raceId, inscriptionId])
  @@index([teamId])
}

model Penalty {
  id           String      @id @default(uuid())
  raceResultId String
  type         PenaltyType
  amount       Int
  reason       String
  createdAt    DateTime    @default(now())

  raceResult RaceResult @relation(fields: [raceResultId], references: [id], onDelete: Cascade)
}

model ChampionshipStanding {
  id          String   @id @default(uuid())
  year        Int
  pilotId     String
  category    Category
  totalPoints Int      @default(0)
  position    Int?
  eventsCount Int      @default(0)
  updatedAt   DateTime @updatedAt

  pilot Pilot @relation(fields: [pilotId], references: [id])

  @@unique([year, pilotId, category])
  @@index([year, category])
}

model ConstructorStanding {
  id          String   @id @default(uuid())
  year        Int
  teamId      String
  category    Category
  totalPoints Int      @default(0)
  position    Int?
  eventsCount Int      @default(0)
  updatedAt   DateTime @updatedAt

  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@unique([year, teamId, category])
  @@index([year, category])
}

model AuditLog {
  id         String   @id @default(uuid())
  userId     String
  userEmail  String
  action     String
  entityType String
  entityId   String
  before     Json?
  after      Json?
  eventId    String?
  createdAt  DateTime @default(now())

  @@index([entityType, entityId])
  @@index([userId])
  @@index([eventId])
  @@index([createdAt])
}
